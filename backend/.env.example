# Required
GEMINI_API_KEY=your-gemini-api-key
SECRET_KEY=generate-a-long-random-string

# Database — SQLite locally; PostgreSQL on Render (see DEPLOY.md)
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional
SQL_ECHO=false
CORS_ORIGINS=["http://localhost:5173","https://dnd-ai-app.vercel.app"]

# Admin: set USERNAME to your account — on restart you get is_admin (approve access requests).
# PASSWORD is only needed when the database has zero users (first deploy).
BOOTSTRAP_ADMIN_USERNAME=your-username-here
# BOOTSTRAP_ADMIN_PASSWORD=only-for-empty-database-first-deploy

# Closed registration (default): visitors submit access requests; admin approves in-app
REGISTRATION_OPEN=false
# REGISTRATION_OPEN=true  # local dev — allow open sign-up