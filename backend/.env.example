# Required
GEMINI_API_KEY=your-gemini-api-key
# Optional overrides (defaults: gemini-3.5-flash / gemini-2.5-flash-lite fallback for PDF)
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite
SECRET_KEY=generate-a-long-random-string

# Database — use PostgreSQL in production (Render)
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional
SQL_ECHO=false
CORS_ORIGINS=["http://localhost:5173","https://dnd-ai-app.vercel.app"]

# Bootstrap first account when database has no users
BOOTSTRAP_ADMIN_USERNAME=dm
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
